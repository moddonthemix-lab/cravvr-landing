# ─────────────────────────────────────────────────────────────────────────────
# Supabase
# ─────────────────────────────────────────────────────────────────────────────
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# ─────────────────────────────────────────────────────────────────────────────
# Clerk — auth provider (replaces Supabase Auth)
#   Publishable key is browser-safe (pk_test_… in dev, pk_live_… in prod).
#   Secret key + webhook secret are server-only — set in Supabase Edge Function
#   env via:  supabase secrets set CLERK_SECRET_KEY=... CLERK_WEBHOOK_SECRET=...
#   Supabase must also be configured to accept Clerk JWTs via Dashboard →
#   Authentication → Sign In / Providers → Third-Party Auth → Clerk.
# ─────────────────────────────────────────────────────────────────────────────
VITE_CLERK_PUBLISHABLE_KEY=pk_test_your_clerk_publishable_key_here
# CLERK_SECRET_KEY=sk_test_your_clerk_secret_key_here
# CLERK_WEBHOOK_SECRET=whsec_your_clerk_webhook_signing_secret

# ─────────────────────────────────────────────────────────────────────────────
# Stripe — client-side (publishable key only)
# Required for online checkout. Use pk_test_… in dev, pk_live_… in prod.
# ─────────────────────────────────────────────────────────────────────────────
VITE_STRIPE_PUBLISHABLE_KEY=pk_test_your_publishable_key_here

# ─────────────────────────────────────────────────────────────────────────────
# Stripe — server-side (set in Supabase Edge Function env, NOT exposed to browser)
#   Set via:  supabase secrets set STRIPE_SECRET_KEY=... STRIPE_WEBHOOK_SECRET=...
# ─────────────────────────────────────────────────────────────────────────────
# STRIPE_SECRET_KEY=sk_test_your_secret_key_here
# STRIPE_WEBHOOK_SECRET=whsec_your_webhook_signing_secret
# STRIPE_CONNECT_RETURN_URL=https://your-domain.com/owner?onboarded=true
# STRIPE_CONNECT_REFRESH_URL=https://your-domain.com/owner?refresh=true

# ─────────────────────────────────────────────────────────────────────────────
# Square — client-side (OAuth application id only, public)
#   Used by the Web Payments SDK to tokenize cards in the browser.
# ─────────────────────────────────────────────────────────────────────────────
VITE_SQUARE_APPLICATION_ID=sandbox-sq0idb-XXXXXXXXXXXXXXXXXXXXXX

# ─────────────────────────────────────────────────────────────────────────────
# Square — server-side (in Edge Function env, NOT exposed to browser)
#   Set via:  supabase secrets set SQUARE_APPLICATION_ID=... SQUARE_APPLICATION_SECRET=... ...
# ─────────────────────────────────────────────────────────────────────────────
# SQUARE_APPLICATION_ID=sandbox-sq0idb-XXXXXXXXXXXXXXXXXXXXXX
# SQUARE_APPLICATION_SECRET=sandbox-sq0csb-XXXXXXXXXXXXXXXXXXXXXXXXXX
# SQUARE_ENVIRONMENT=sandbox    # or 'production'
# SQUARE_OAUTH_STATE_SECRET=    # any 32+ char random string (HMAC for OAuth state)
# SQUARE_WEBHOOK_SIGNATURE_KEY= # from Square dashboard → Webhooks → Signature key
# SQUARE_WEBHOOK_URL=https://<project-ref>.supabase.co/functions/v1/square-webhook
# SQUARE_RETURN_URL=https://your-domain.com/owner

# ─────────────────────────────────────────────────────────────────────────────
# Resend (server-side, in Edge Function env)
#   Set via:  supabase secrets set RESEND_API_KEY=... RESEND_FROM_EMAIL=...
#   Templates live in supabase/functions/_shared/emails/ as react-email tsx.
# ─────────────────────────────────────────────────────────────────────────────
# RESEND_API_KEY=re_your_api_key_here
# RESEND_FROM_EMAIL=noreply@cravvr.com
# RESEND_FROM_NAME=Cravvr
# SITE_URL=https://cravvr.com

# ─────────────────────────────────────────────────────────────────────────────
# MapTiler — vector map tiles (Positron style)
#   Free tier: 100k tile loads/mo. Sign up at https://www.maptiler.com/cloud/
# ─────────────────────────────────────────────────────────────────────────────
VITE_MAPTILER_KEY=

# ─────────────────────────────────────────────────────────────────────────────
# Analytics — browser pixels (leave blank to disable in dev)
# ─────────────────────────────────────────────────────────────────────────────
VITE_META_PIXEL_ID=
VITE_GA4_MEASUREMENT_ID=
VITE_TIKTOK_PIXEL_ID=
# Microsoft Clarity — free session replays + heatmaps. Project ID is browser-safe.
# Get one at https://clarity.microsoft.com → Settings → Setup → "Clarity project ID"
VITE_CLARITY_PROJECT_ID=

# ─────────────────────────────────────────────────────────────────────────────
# Analytics — server-side Conversions APIs (set in Edge Function env, NOT exposed to browser)
# ─────────────────────────────────────────────────────────────────────────────
# META_CAPI_PIXEL_ID=
# META_CAPI_ACCESS_TOKEN=
# GOOGLE_MEASUREMENT_PROTOCOL_API_SECRET=
# TIKTOK_EVENTS_API_TOKEN=
# TIKTOK_PIXEL_CODE=

# ─────────────────────────────────────────────────────────────────────────────
# Truck-operator lead pipeline (set in Edge Function env, NOT exposed to browser)
#   Used by supabase/functions/truck-lead/index.ts
#   Set via:
#     supabase secrets set \
#       SLACK_LEADS_WEBHOOK_URL=https://hooks.slack.com/services/... \
#       KLAVIYO_API_KEY=pk_... \
#       KLAVIYO_LEADS_LIST_ID=ABCDEF
#
#   Slack webhook: api.slack.com/messaging/webhooks
#   Klaviyo API key (server-side, private): klaviyo.com → Account → Settings →
#     API Keys → "Create Private API Key" with scopes:
#       events:write, profiles:write, lists:write
#   Klaviyo list ID: Lists & Segments → your list → copy 6-char code from URL
# ─────────────────────────────────────────────────────────────────────────────
# SLACK_LEADS_WEBHOOK_URL=
# KLAVIYO_API_KEY=
# KLAVIYO_LEADS_LIST_ID=
